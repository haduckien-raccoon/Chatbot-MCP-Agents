# Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_TIMEOUT_MS=8000

# OpenWeather
OPENWEATHER_API_KEY=
WEATHER_DEFAULT_CITY=Ho Chi Minh City

# Exa Search
EXA_API_KEY=

# NewsAPI
NEWS_API_KEY=

# Brave Search
BRAVE_API_KEY=

# GitHub (optional)
GITHUB_PERSONAL_ACCESS_TOKEN=

# Knowledge base directory (relative to project root)
DATA_DIR=../data

# Server
HOST=0.0.0.0
PORT=8000
