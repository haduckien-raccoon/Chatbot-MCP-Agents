GROQ_MODELS=allam-2-7b,groq/compound,groq/compound-mini,llama-3.1-8b-instant,llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct,meta-llama/llama-prompt-guard-2-22m,meta-llama/llama-prompt-guard-2-86m,moonshotai/kimi-k2-instruct,moonshotai/kimi-k2-instruct-0905,openai/gpt-oss-120b,openai/gpt-oss-20b,openai/gpt-oss-safeguard-20b,qwen/qwen3-32b

# OpenWeather
OPENWEATHER_API_KEY=
WEATHER_DEFAULT_CITY=Ho Chi Minh City

# Visual Crossing Weather
VISUALCROSSING_API_KEY=FXYZEBLW5H9YWE75XG8N84UTN

# Exa Search
EXA_API_KEY=

# NewsAPI
NEWS_API_KEY=

# Brave Search
